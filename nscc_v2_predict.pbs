#!/bin/bash
#PBS -N tpug_v2_pred
#PBS -P 52001004
#PBS -l select=1:ngpus=1
#PBS -l walltime=02:00:00
#PBS -j oe
#PBS -o tpug_v2_pred.log

cd $PBS_O_WORKDIR
module load miniforge3
eval "$(conda shell.bash hook)"
conda activate tpugraphs

python3 predict.py 2>&1
python3 combine_submissions.py 2>&1

echo "Done: $(date)"
